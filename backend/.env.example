# Required for Spotify metadata and public playlists.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Optional. Enables private Spotify resources when the token has the required scopes.
SPOTIFY_REFRESH_TOKEN=

# Path to an exported Netscape-format YouTube cookies file. Keep the real file private.
# YTDLP_COOKIES_PATH=C:\\secure\\youtube-cookies.txt
# Or ask yt-dlp to read the current browser profile (for example: chrome, firefox).
# YTDLP_COOKIES_FROM_BROWSER=chrome

# Optional override. Leave unset unless yt-dlp asks for a specific player client.
# YTDLP_YOUTUBE_PLAYER_CLIENTS=android
# MPV-safe YouTube fallback. Defaults are chosen to avoid GoogleVideo 403s in MPV.
# YTDLP_YOUTUBE_MPV_SAFE_CLIENT=android
# YTDLP_YOUTUBE_MPV_SAFE_FORMAT=18/best[ext=mp4][height<=360]/best[ext=mp4]/best/bestaudio/best
# Optional compatibility switch for networks where IPv6 causes extractor failures.
# YTDLP_FORCE_IPV4=true

# Audio profile at startup: balanced or xbox. You can also toggle it in the app.
# AUDIO_PROFILE=balanced
# Lower latency defaults for track changes. Increase only if your network glitches.
# MPV_AUDIO_BUFFER_SEC=2.0
# MPV_DEMUXER_MAX_BYTES=256MiB
# MPV_DEMUXER_READAHEAD_SEC=10
# How many upcoming tracks the backend quietly prepares in advance.
# PLAYER_PRELOAD_AHEAD=3
# PLAYER_PRELOAD_CACHE_MAX=8

# The virtual input used by mpv on Windows. This must be a VoiceMeeter virtual input.
WINDOWS_MPV_AUDIO_DEVICE=wasapi/{replace-with-your-voicemeeter-device-id}

# Linux virtual sink used as the mpv output; its .monitor is the virtual input.
LINUX_VIRTUAL_SINK_NAME=xmbot_sink
